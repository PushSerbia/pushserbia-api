# Environment variables template for pushserbia-api
# Copy this file to `.env` and fill in the values as needed.

# --- App basics ---
NODE_ENV=development
PORT=3000

# --- Database ---
# Either provide a single DATABASE_URL or individual connection params
# Matches docker-compose defaults (postgres/postgres on localhost:5432)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pushserbia
# For local dockerized Postgres, SSL should be disabled
DATABASE_SSL=false
# Optional: CA certificate for SSL connections (e.g. for cloud-hosted databases)
# DATABASE_CA_CERT=

# Example for a cloud Postgres provider (requires SSL):
# Recommended for Neon: use the pooled connection URL (ends with -pooler)
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
# DATABASE_SSL=true

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pushserbia
POSTGRES_PORT=5432

# Set to false in production. Enables TypeORM auto-sync of schema.
# WARNING: Should ALWAYS be false in production to prevent data loss.
TYPEORM_SYNCHRONIZE=true

# Set to true to auto-run pending migrations on app startup.
# Recommended for production. In dev, you can run manually via: npm run migration:run
TYPEORM_MIGRATIONS_RUN=false

# --- Auth / Frontend URLs ---
# Comma-separated list of allowed callback origins
AUTH_CALLBACK_URLS=http://localhost:4200,https://pushserbia.com
AUTH_PRODUCTION_LOGIN_PAGE=https://pushserbia.com/auth
AUTH_LOGIN_PAGE_URL=autentikacija
AUTH_ACCOUNT_PAGE_URL=autentikacija/preusmeravanje/linkedin
AUTH_SECURE_COOKIE=false

# --- CORS ---
# Comma-separated list of allowed CORS origins. Supports:
# - Plain origins (e.g., http://localhost:4200)
# - Regex via re:/pattern/ or by providing ^...$ (e.g., ^https://.*\.vercel\.app$)
# Examples below mirror current defaults:
CORS_ORIGINS=http://localhost:4000,http://localhost:4200

# --- LinkedIn OAuth ---
LINKEDIN_REDIRECT_URI=http://localhost:3000/v1/auth/redirect/linkedin?callback=
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# --- Mailchimp ---
MAILCHIMP_ENABLE=false
MAILCHIMP_TOKEN=your_mailchimp_api_key
MAILCHIMP_LIMIT=2000

# --- Firebase Admin SDK ---
FIREBASE_PROJECT_ID=your_firebase_project_id
# Note: keep quotes for multiline private key
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your-project.iam.gserviceaccount.com
FIREBASE_API_KEY=your_firebase_api_key

# --- Unsplash ---
UNSPLASH_BASE_URL=https://api.unsplash.com/
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
